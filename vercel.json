{
    "version": 2,
    "builds": [
        {
            "src": "src/server.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "swagger.yaml"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "methods": [
                "OPTIONS"
            ],
            "headers": {
                "Access-Control-Allow-Credentials": "true",
                "Access-Control-Allow-Origin": "https://galan-lab7-intprog.onrender.com",
                "Access-Control-Allow-Methods": "GET,OPTIONS,PATCH,DELETE,POST,PUT",
                "Access-Control-Allow-Headers": "Content-Type, Authorization"
            },
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "src/server.ts"
        }
    ]
}